@model IEnumerable<FeedbackUsers.Models.FeedbackModel>

@{
    ViewData["Title"] = "Feedback List";
}

<h2>Feedback List</h2>

<a asp-action="Create" class="btn btn-success mb-3">Write New Feedback</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Feedback</th>            
            <th>Timestamp</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Feedback</td>
                <td>@item.Timestamp?.ToString("g")</td>
            </tr>
        }
    </tbody>
</table>

